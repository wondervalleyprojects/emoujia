# Gemini API Key (Get at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Email Configuration (Nodemailer Gmail SMTP)
# GMAIL_USER should be your PRIMARY Gmail address.
GMAIL_USER=
# GMAIL_APP_PASSWORD must be a 16-character App Password generated in Google Account settings.
GMAIL_APP_PASSWORD=

# Base URL for the application (used in emails and share cards)
VITE_APP_URL=

# Firebase Configuration
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
